# Copy this file to .env and fill real values before running setup.sh --up
# Do NOT commit .env with real secrets.

# Required
NVIDIA_API_KEY=your_nvidia_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
MAX_CONCURRENT_REQUESTS=1

# Optional
# If omitted, pdf-service uses docker-compose default fallback.
# MODEL_API_URL=http://pdf-api:8004

# Optional: override default TTS voices (must be usable by your ElevenLabs plan)
# DEFAULT_VOICE_1=nPczCjzI2devNBz1zQrb
# DEFAULT_VOICE_2=EXAVITQu4vr4xnSDxMaL
